---
import MainLayout from "../layout/Layout.astro";
---

<MainLayout title="My Top Ten">
    <link
        rel="stylesheet"
        href="//cdn.datatables.net/2.3.2/css/dataTables.dataTables.min.css"
    />
    <section class="py-5 header">
        <div class="wrapper">
            <h1>My Songs</h1>
        </div>
    </section>
    <section class="wrapper py-5">
        <div class="content">
            <div class="py-5" id="playlistActions">
                <input type="text" class="form-input" id="newPlaylistName" placeholder="Playlist name" />
                <button class="btn btn-primary" id="createPlaylist">Create Playlist</button>
                <span class="mx-5">OR</span>
                <button class="btn btn-light" id="importSpotify">Import from Spotify</button>
            </div>

            <div id="playlistsContainer" class="py-4">
                <h2>Your Playlists</h2>
                <div id="playlistList" class="flex"></div>
                <div id="noPlaylists" class="text-muted" style="display:none;">You don't have any playlists yet.</div>
            </div>

            <div id="playlistDetails" style="display:none;">
                <div class="d-flex" style="justify-content: space-between; align-items: center;">
                    <h3 id="currentPlaylistName"></h3>
                    <button class="btn btn-light" id="deletePlaylist">Delete Playlist</button>
                </div>
                <div class="text-right">
                    <button class="btn btn-primary" id="addSongBtn">Add Song</button>
                </div>
                <div id="addSongForm" style="display:none; margin-top:1rem;">
                    <input type="text" id="songTitle" placeholder="Song title" class="form-input" />
                    <input type="text" id="songArtist" placeholder="Artist" class="form-input" />
                    <button class="btn btn-primary" id="saveSongBtn">Save Song</button>
                    <button class="btn btn-light" id="cancelSongBtn">Cancel</button>
                </div>
                <div>
                    <table class="dataTable" id="myPlayList">
                        <thead>
                            <tr>
                                <th>Song</th>
                                <th>Artist</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="songsTableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <style>
            ul {
                padding: 0;
            }
            ol li {
                padding: 0.75rem;
            }
            input {
                height: 23px;
                padding-left: 5px;
                border: 1px solid var(--static11);
            }
            .mx-5 {
                margin-left: 1rem;
                margin-right: 1rem;
            }
            .img img {
                width: 96px;
                height: 96px;
                border-radius: 50%;
            }
            .item {
                width: 100px;
                display: inline-block;
            }
            .flex {
                display: flex;
                flex-wrap: wrap;
                gap: 10px;
            }
            .pr-3 {
                padding-right: 3rem;
            }
            .py-1 {
                padding: 2rem 0;
            }
            .d-block {
                display: block;
            }
            .w-200 {
                width: 200px;
            }
            .border-light {
                border-bottom: 1px solid #ddd;
            }
            .txt-accent {
                color: var(--accent);
                cursor: pointer;
            }
            .grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
                gap: 1rem;
            }
            .playlist-card {
                background: var(--primary);
                border-radius: 0.35rem;
                padding: 1rem;
                box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
                cursor: pointer;
                transition: transform 0.2s ease, box-shadow 0.2s ease;
            }
            .playlist-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 0 16px rgba(0, 0, 0, 0.2);
            }
            .playlist-card.active {
                outline: 2px solid var(--accent);
            }

            @media (min-width: 768px) {
                .d-md-inline-block {
                    display: inline-block !important;
                }
            }

            @media screen and (max-width: 480px) {
                label {
                    padding: 15px 10px;
                    display: block;
                }
            }

            @keyframes inUp {
                0% {
                    opacity: 0;
                    transform: translateY(100px);
                }
                90% {
                    transform: translateY(-10px);
                }
                100% {
                    opacity: 1;
                    transform: translateY(0);
                }
            }
        </style>
    </section>
</MainLayout>
